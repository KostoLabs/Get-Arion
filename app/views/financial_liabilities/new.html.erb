<% if params[:step] == "method_select" %>
  <%= render "accounts/new/method_selector",
             path: new_financial_liability_path(return_to: params[:return_to]),
             us_link_token: @us_link_token,
             eu_link_token: @eu_link_token %>
<% else %>
  <%= modal_form_wrapper title: t(".title") do %>
    <%= render "financial_liabilities/form", account: @account, url: financial_liabilities_path %>
  <% end %>
<% end %>
