<%# locals: (account:, url:) %>
<%= render "accounts/form", account: account, url: url do |form| %>
  <hr class="my-3">

  <%= form.fields_for :accountable_attributes do |f| %>
    <%= f.select :storage,
          Inventory::STORAGES.map { |s| [t("inventories.form.storage.#{s}"), s] },
          prompt: t("inventories.form.storage_prompt"),
          required: true %>

    <%= f.select :inventory_type,
          Inventory::INVENTORY_TYPES.map { |t| [t("inventories.form.type.#{t.parameterize(separator: '_')}"), t] },
          prompt: t("inventories.form.type_prompt"),
          required: true %>

    <%= f.text_field :address,
          placeholder: "numéro et rue",
          label: t("inventories.form.address") %>

    <div class="grid grid-cols-2 gap-4">
      <%= f.text_field :city,
            placeholder: "Ex. Paris",
            label: t("inventories.form.city") %>

      <%= f.text_field :postal_code,
            placeholder: "Ex. 75000",
            label: t("inventories.form.postal_code") %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <%= f.text_field :country,
            placeholder: "Ex. France",
            label: t("inventories.form.country") %>

      <%= f.text_field :region,
            placeholder: "Ex. Île-de-France",
            label: t("inventories.form.region") %>
    </div>
  <% end %>
<% end %>
