<div class="max-w-xl mx-auto bg-white p-8 rounded-2xl border border-gray-300 shadow-sm">
  <div class="mb-6">
    <h2 class="text-2xl font-semibold text-primary mb-1 flex items-center gap-2">
      <%= lucide_icon "mail", class: "w-6 h-6 text-primary" %>
      Contacter le support
    </h2>
    <p class="text-sm text-gray-500">
      Un souci ou une question ? Laissez-nous un message, on revient vers vous rapidement.
    </p>
  </div>

  <%= form_with model: @message, url: contacts_path, local: true do |form| %>
    <div class="space-y-5">
      <div>
        <%= form.label :name, "Nom", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :name, class: "w-full px-3 py-1.5 border border-gray-300 rounded-md bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400 transition" %>
      </div>

      <div>
        <%= form.label :email, "E-mail", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.email_field :email, class: "w-full px-3 py-1.5 border border-gray-300 rounded-md bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400 transition" %>
      </div>

      <div>
        <%= form.label :subject, "Sujet", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :subject, class: "w-full px-3 py-1.5 border border-gray-300 rounded-md bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400 transition" %>
      </div>

      <div>
        <%= form.label :content, "Message", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :content, rows: 5, class: "w-full px-3 py-1.5 border border-gray-300 rounded-md bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400 resize-none transition" %>
      </div>

      <div>
        <%= form.submit "Envoyer le message", class: "bg-black hover:bg-gray-800 text-white font-semibold py-2.5 px-6 rounded-md shadow-sm transition-colors mx-auto block" %>
      </div>
    </div>
  <% end %>
</div>
